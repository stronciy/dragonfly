generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  customer
  performer
  admin
}

enum OrderStatus {
  draft
  published
  accepted
  pending_deposit
  requires_confirmation
  confirmed
  started
  completed
  arbitration
  cancelled
}

enum EscrowStatus {
  locked
  released
  forfeited
}

enum EscrowRole {
  customer
  performer
}

enum PaymentProvider {
  stripe
  liqpay
}

enum PaymentStatus {
  requires_action
  processing
  succeeded
  failed
  canceled
}

enum NotificationType {
  system
  order
  deposit
  marketplace
  arbitration
  payout
}

enum DevicePlatform {
  ios
  android
}

enum CoverageMode {
  radius
  country
}

enum ArbitrationStatus {
  opened
  in_review
  resolved
  cancelled
}

enum PayoutStatus {
  pending
  paid
  failed
}

enum TaxSystem {
  FOP_2
  FOP_3
  LLC
  OTHER
}

model ServiceCategory {
  id   String @id @default(cuid())
  name String
  sort Int @default(0)

  subcategories ServiceSubcategory[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([sort, name])
  @@map("service_category")
}

model ServiceSubcategory {
  id         String @id @default(cuid())
  categoryId String @map("category_id")
  name       String
  sort       Int @default(0)

  pricePerHa Decimal? @db.Decimal(12, 2) @map("price_per_ha")
  minPrice   Decimal? @db.Decimal(12, 2) @map("min_price")
  currency   String   @default("UAH") @db.VarChar(8)

  category ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  types    ServiceType[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([categoryId, sort, name])
  @@map("service_subcategory")
}

model ServiceType {
  id            String
  subcategoryId String  @map("subcategory_id")
  name          String
  sort          Int     @default(0)

  pricePerHa Decimal? @db.Decimal(12, 2) @map("price_per_ha")
  minPrice   Decimal? @db.Decimal(12, 2) @map("min_price")
  currency   String   @default("UAH") @db.VarChar(8)

  subcategory ServiceSubcategory @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([subcategoryId, id])
  @@index([subcategoryId, sort, name])
  @@map("service_type")
}

model Crop {
  id      String @id @default(cuid())
  name    String
  iconKey String? @map("icon_key")
  sort    Int @default(0)

  customerCropStats CustomerCropStat[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([sort, name])
  @@map("crops")
}

model User {
  id           String   @id @default(cuid())
  role         UserRole @default(customer)
  name         String
  email        String   @unique
  phone        String?  @db.VarChar(32)
  passwordHash String   @map("passwordHash")

  biometricsEnabled Boolean @default(false) @map("biometricsEnabled")
  twoFactorSecret   String? @map("twoFactorSecret")
  twoFactorEnabledAt DateTime? @map("twoFactorEnabledAt")

  createdAt DateTime @default(now()) @map("createdAt")
  updatedAt DateTime @updatedAt @map("updatedAt")

  customerProfile  CustomerProfile?
  performerProfile PerformerProfile?

  refreshTokens RefreshToken[]
  devices       Device[]
  notifications Notification[]
  twoFactorSetups TwoFactorSetup[]

  customerOrders  Order[] @relation("CustomerOrders")
  performerOrders Order[] @relation("PerformerOrders")

  escrowLocks EscrowLock[]
  payments   Payment[]
  payouts     Payout[]
  reserveTx   ReserveTransaction[]
  authoredReviews Review[] @relation("AuthoredReviews")
  performerReviews Review[] @relation("PerformerReviews")

  @@map("user")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String   @map("userId")
  tokenHash String   @unique @map("tokenHash")
  expiresAt DateTime @map("expiresAt")
  revokedAt DateTime? @map("revokedAt")
  createdAt DateTime @default(now()) @map("createdAt")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_token")
}

model CustomerProfile {
  id     String @id @default(cuid())
  userId String @unique @map("userId")

  companyName  String? @map("companyName")
  companyEdrpou String? @map("companyEdrpou")
  billingEmail String? @map("billingEmail")
  iban         String? @map("iban")
  taxSystem    TaxSystem? @map("taxSystem")
  vatPayer     Boolean @default(false) @map("vatPayer")
  legalAddress String? @map("legalAddress")

  createdAt DateTime @default(now()) @map("createdAt")
  updatedAt DateTime @updatedAt @map("updatedAt")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  fields Field[]
  cropStats CustomerCropStat[]

  @@map("customer_profile")
}

model Review {
  id String @id @default(cuid())

  orderId         String @map("orderId")
  performerUserId String @map("performerUserId")
  authorUserId    String @map("authorUserId")

  rating Int
  text   String? @db.Text

  createdAt DateTime @default(now()) @map("createdAt")

  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  performer User  @relation("PerformerReviews", fields: [performerUserId], references: [id], onDelete: Cascade)
  author    User  @relation("AuthoredReviews", fields: [authorUserId], references: [id], onDelete: Cascade)

  @@unique([orderId, authorUserId], name: "uniq_review_order_author")
  @@index([performerUserId, createdAt])
  @@map("reviews")
}

model TwoFactorSetup {
  id String @id @default(cuid())

  userId String @map("user_id")
  secret String

  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")
  consumedAt DateTime? @map("consumed_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("two_factor_setups")
}

model CustomerCropStat {
  id String @id @default(cuid())

  customerUserId String @map("customer_user_id")
  season         Int
  cropId         String @map("crop_id")

  areaHa Decimal @db.Decimal(10, 2) @map("area_ha")
  yieldT Decimal @db.Decimal(12, 2) @map("yield_t")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  customer CustomerProfile @relation(fields: [customerUserId], references: [userId], onDelete: Cascade)
  crop     Crop            @relation(fields: [cropId], references: [id], onDelete: Cascade)

  @@unique([customerUserId, season, cropId], name: "uniq_cropstat_customer_season_crop")
  @@index([customerUserId, season])
  @@map("customer_crop_stat")
}

model PerformerProfile {
  id     String @id @default(cuid())
  userId String @unique @map("userId")

  companyName  String? @map("companyName")
  edrpou       String? @map("edrpou")
  billingEmail String? @map("billingEmail")
  iban         String? @map("iban")
  taxSystem    TaxSystem? @map("taxSystem")
  vatPayer     Boolean @default(false) @map("vatPayer")
  legalAddress String? @map("legalAddress")
  
  baseLocationLabel String? @map("baseLocationLabel")
  baseLatitude      Float?  @map("baseLatitude")
  baseLongitude     Float?  @map("baseLongitude")

  coverageMode      String? @default("radius") @map("coverageMode")
  coverageRadiusKm  Int?    @default(50) @map("coverageRadiusKm")

  avgRating    Float   @default(0) @map("avgRating")
  reviewCount  Int     @default(0) @map("reviewCount")

  services PerformerService[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("performer_profile")
}

model PerformerService {
  id               String  @id @default(cuid())
  performerUserId  String  @map("performerUserId")
  serviceCategoryId String @map("serviceCategoryId")
  serviceSubCategoryId String @map("serviceSubCategoryId")
  serviceTypeId    String? @map("serviceTypeId")

  createdAt DateTime @default(now()) @map("createdAt")

  performer PerformerProfile @relation(fields: [performerUserId], references: [userId], onDelete: Cascade)

  @@unique([performerUserId, serviceCategoryId, serviceSubCategoryId, serviceTypeId], name: "uniq_performer_service")
  @@index([performerUserId])
  @@index([serviceCategoryId, serviceSubCategoryId, serviceTypeId])
  @@map("performer_service")
}

model Field {
  id          String @id @default(cuid())
  ownerUserId String @map("owner_user_id")

  name       String
  areaHa     Decimal @db.Decimal(10, 2) @map("area_ha")
  regionName String? @map("region_name")

  geometry Json? @map("geometry")

  centroidLat Decimal? @db.Decimal(9, 6) @map("centroid_lat")
  centroidLng Decimal? @db.Decimal(9, 6) @map("centroid_lng")

  status String? @db.VarChar(32)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  owner CustomerProfile @relation(fields: [ownerUserId], references: [userId], onDelete: Cascade)

  @@index([ownerUserId])
  @@map("field")
}

model Order {
  id String @id @default(cuid())

  customerUserId  String  @map("customer_user_id")
  performerUserId String? @map("performer_user_id")

  serviceCategoryId    String  @map("service_category_id")
  serviceSubCategoryId String  @map("service_subcategory_id")
  serviceTypeId        String? @map("service_type_id")

  areaHa Decimal @db.Decimal(10, 2) @map("area_ha")

  dateFrom DateTime? @map("date_from")
  dateTo   DateTime? @map("date_to")

  locationLabel String  @map("location_label")
  regionName    String? @map("region_name")

  lat         Decimal @db.Decimal(9, 6) @map("lat")
  lng         Decimal @db.Decimal(9, 6) @map("lng")

  comment String? @db.Text

  budget   Decimal @db.Decimal(12, 2)
  currency String  @default("UAH") @db.VarChar(8)

  status OrderStatus @default(draft)

  acceptedAt      DateTime? @map("accepted_at")
  depositDeadline DateTime? @map("deposit_deadline")

  evidencePhotos Json? @map("evidence_photos")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  customer  User  @relation("CustomerOrders", fields: [customerUserId], references: [id], onDelete: Restrict)
  performer User? @relation("PerformerOrders", fields: [performerUserId], references: [id], onDelete: Restrict)

  escrowLocks     EscrowLock[]
  statusEvents    OrderStatusEvent[]
  matches         OrderMatch[]
  arbitrationCase ArbitrationCase?
  payments        Payment[]
  reportMedia     OrderReportMedia[]
  agreement       Agreement?
  reviews         Review[]

  @@index([customerUserId, status, createdAt])
  @@index([performerUserId, status, createdAt])
  @@index([status, createdAt])
  @@index([serviceCategoryId, serviceSubCategoryId, serviceTypeId])
  @@map("order")
}

model EscrowLock {
  id      String @id @default(cuid())
  orderId String @map("order_id")
  userId  String @map("user_id")

  role   EscrowRole
  status EscrowStatus @default(locked)

  amount   Decimal @db.Decimal(12, 2)
  currency String  @default("UAH") @db.VarChar(8)

  provider    PaymentProvider? @map("provider")
  providerRef String?          @map("provider_ref")

  createdAt  DateTime  @default(now()) @map("created_at")
  releasedAt DateTime? @map("released_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orderId, role], name: "uniq_order_role_lock")
  @@index([userId, status])
  @@index([orderId, status])
  @@map("escrow_lock")
}

model Payment {
  id String @id @default(cuid())

  orderId String @map("order_id")
  userId  String @map("user_id")

  provider         PaymentProvider
  providerIntentId String @map("provider_intent_id")
  status           PaymentStatus

  amount   Decimal @db.Decimal(12, 2)
  currency String  @default("UAH") @db.VarChar(8)

  raw Json? @map("raw")

  createdAt DateTime @default(now()) @map("created_at")
  paidAt    DateTime? @map("paid_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerIntentId], name: "uniq_provider_intent")
  @@index([orderId])
  @@index([userId, createdAt])
  @@map("payment")
}

model OrderStatusEvent {
  id      String @id @default(cuid())
  orderId String @map("order_id")

  fromStatus OrderStatus? @map("from_status")
  toStatus   OrderStatus  @map("to_status")

  note String? @db.Text
  at   DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, at])
  @@map("order_status_event")
}

model OrderMatch {
  id String @id @default(cuid())

  performerUserId String @map("performer_user_id")
  orderId         String @map("order_id")

  distanceKm Decimal @db.Decimal(10, 2) @map("distance_km")
  createdAt   DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([performerUserId, orderId], name: "uniq_performer_order_match")
  @@index([performerUserId, createdAt])
  @@index([orderId])
  @@map("order_match")
}

model ArbitrationCase {
  id      String @id @default(cuid())
  orderId String @unique @map("order_id")

  openedByUserId String @map("opened_by_user_id")
  reason         String @db.Text
  status         ArbitrationStatus @default(opened)

  createdAt  DateTime  @default(now()) @map("created_at")
  resolvedAt DateTime? @map("resolved_at")

  media ArbitrationMedia[]

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@map("arbitration_case")
}

model ArbitrationMedia {
  id     String @id @default(cuid())
  caseId String @map("case_id")

  url      String
  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")

  case ArbitrationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId, createdAt])
  @@map("arbitration_media")
}

model Notification {
  id     String @id @default(cuid())
  userId String @map("user_id")

  type    NotificationType
  title   String
  message String
  data    Json?

  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@map("notification")
}

model Device {
  id     String @id @default(cuid())
  userId String @map("user_id")

  expoPushToken String @unique @map("expo_push_token")
  platform      DevicePlatform
  deviceId      String? @map("device_id")
  appVersion    String? @map("app_version")

  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@map("device")
}

model OrderReportMedia {
  id      String @id @default(cuid())
  orderId String @map("order_id")

  url     String
  caption String? @db.Text
  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@map("order_report_media")
}

model Agreement {
  id      String @id @default(cuid())
  orderId String @unique @map("order_id")

  customerUserId  String @map("customer_user_id")
  performerUserId String @map("performer_user_id")

  amountTotal Decimal @db.Decimal(12, 2) @map("amount_total")
  currency    String  @default("UAH") @db.VarChar(8)

  performedAt DateTime? @map("performed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  documents AgreementDocument[]

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([customerUserId, createdAt])
  @@index([performerUserId, createdAt])
  @@map("agreement")
}

model AgreementDocument {
  id          String @id @default(cuid())
  agreementId String @map("agreement_id")

  type String @db.VarChar(32)
  url  String

  createdAt DateTime @default(now()) @map("created_at")

  agreement Agreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)

  @@index([agreementId, createdAt])
  @@map("agreement_document")
}

model Payout {
  id              String @id @default(cuid())
  performerUserId String @map("performer_user_id")

  amount   Decimal @db.Decimal(12, 2)
  currency String  @default("UAH") @db.VarChar(8)

  status      PayoutStatus @default(pending)
  providerRef String?      @map("provider_ref")

  createdAt DateTime  @default(now()) @map("created_at")
  paidAt    DateTime? @map("paid_at")

  performer User @relation(fields: [performerUserId], references: [id], onDelete: Cascade)

  @@index([performerUserId, createdAt])
  @@index([status, createdAt])
  @@map("payout")
}

model ReserveTransaction {
  id              String @id @default(cuid())
  performerUserId String @map("performer_user_id")
  orderId         String? @map("order_id")

  title     String
  amount    Decimal @db.Decimal(12, 2)
  direction String  @db.VarChar(8)

  createdAt DateTime @default(now()) @map("created_at")

  performer User @relation(fields: [performerUserId], references: [id], onDelete: Cascade)

  @@index([performerUserId, createdAt])
  @@index([orderId])
  @@map("reserve_transaction")
}
