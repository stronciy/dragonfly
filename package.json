{
  "name": "dragonfly_backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node server.js",
    "dev:next": "next dev",
    "build": "rm -rf .next && npm run prisma:generate && next build",
    "build:with-db-reset": "npm run db:reset && npm run prisma:generate && next build",
    "build:worker": "tsc -p tsconfig.worker.json",
    "start": "node server.js",
    "start:next": "next start",
    "lint": "next lint",
    "test": "npm run test:unit",
    "test:unit": "tsc -p tsconfig.test.json && node --test dist-tests/tests/**/*.test.js",
    "worker": "node dist/workers/run.js",
    "prisma:generate": "prisma generate",
    "db:deploy": "prisma migrate deploy --config prisma.config.ts",
    "db:reset": "prisma migrate reset --force --config prisma.config.ts",
    "db:status": "prisma migrate status --config prisma.config.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.71.0",
    "dotenv": "^17.3.1",
    "expo-server-sdk": "^6.1.0",
    "ioredis": "^5.10.0",
    "jose": "^6.2.1",
    "next": "^15.5.13",
    "otplib": "^13.3.0",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "stripe": "^20.4.1",
    "zod": "^4.3.6",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "^15.5.13",
    "prisma": "^7.5.0",
    "typescript": "^5"
  }
}
