{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["dom", "esnext"],
    "jsx": "preserve"
  },
  "include": [
    "src/workers/**/*.ts",
    "src/queues/**/*.ts",
    "src/services/**/*.ts",
    "src/lib/**/*.ts",
    "src/generated/**/*.ts"
  ]
}
